      "timeout_seconds": 300,
      "max_retries": 3,
      "wire_api": "responses"
    },
    "claude": {
      "provider": "openai-compatible",
      "base_url": "http://2000.run:6543",
      "api_key_env": "CCSWITCH_CLAUDE_API_KEY",
      "timeout_seconds": 300,
      "max_retries": 3,
      "wire_api": "responses"
    }
  },
  "models": {
    "orchestrator": {
      "name": "gpt-5.4",
