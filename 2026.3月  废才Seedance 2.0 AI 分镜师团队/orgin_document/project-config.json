    },
    "storyboard_artist": {
      "name": "gpt-5.4",
      "provider": "claude",
      "temperature": 0.5,
      "max_tokens": 12000
    },
    "compliance_review": {
      "name": "gpt-5.4",
      "provider": "claude",
      "temperature": 0.1,
      "max_tokens": 8000
    }
  },
  "review": {
    "max_auto_fix_rounds": 3
  },
  "paths": {
    "scripts": "script",
    "assets": "assets",
    "outputs": "outputs",
    "logs": "logs",
    "sessions": ".sessions",
    "reports": "reports"
  }
